# Environment: dev | staging | prod
NODE_ENV=dev

# Transport: stdio (default, for local AI clients) | http (for remote deployment)
TRANSPORT=stdio
PORT=3000

# Kubernetes
# Use 'kubeconfig' for file-based auth, 'incluster' for in-cluster auth
K8S_AUTH_MODE=kubeconfig
K8S_KUBECONFIG_PATH=~/.kube/config
# K8S_API_SERVER=https://your-k8s-api-server:6443
# K8S_TOKEN=your-service-account-token
# K8S_CA_CERT_PATH=/path/to/ca.crt

# Prometheus
PROMETHEUS_URL=http://localhost:9090

# Loki
LOKI_URL=http://localhost:3100

# Optional: Basic auth for Prometheus/Loki
# PROMETHEUS_USERNAME=
# PROMETHEUS_PASSWORD=
# LOKI_USERNAME=
# LOKI_PASSWORD=

# Log level: error | warn | info | http | debug (default: debug in dev, info in prod)
# LOG_LEVEL=info
